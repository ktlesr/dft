// DFT Portal — Prisma Schema v1
// PostgreSQL 16+

generator client {
  provider      = "prisma-client-js"
  // "native" covers local dev; the explicit targets cover Windows dev
  // machines and the Debian-based Docker runner used in production.
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserStatus {
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
  REJECTED
}

enum Role {
  USER
  MODERATOR
  RAPPORTEUR
  ADVISOR
  KS
  ADMIN
}

enum BoardScope {
  GENERAL
  GROUP
}

enum BoardPostKind {
  NEWS
  ANNOUNCEMENT
  SUGGESTION
  IDEA
  RESOURCE
  DISCUSSION
  MEETING
  EVENT
  OTHER
}

enum BoardPostStatus {
  PUBLISHED
  HIDDEN
  REMOVED
}

enum NoticeScope {
  GENERAL  // tüm aktif üyelere açık; yalnızca admin yazar
  GROUP    // yalnızca ilgili grup üyeleri görür; admin veya o grubun moderatörü yazar
}

enum ProjectApplicationKind {
  BIREYSEL
  DFT_ILE_BIRLIKTE
}

enum ProjectApplicationStatus {
  PLANLANIYOR
  BASVURULDU
  DEGERLENDIRMEDE
  KABUL
  RED
  GERI_CEKILDI
}

enum ProjectIdeaStage {
  FIKIR
  ON_ARASTIRMA
  HAZIRLIK
  ORTAK_ARAYISI
  BASVURUYA_HAZIR
}

enum ReportKind {
  YOL_HARITASI
  DORT_AYLIK_1
  DORT_AYLIK_2
  DORT_AYLIK_3
  KAPANIS
}

enum GroupNoteKind {
  ADVISOR_NOTE
  KS_NOTE
}

enum DocumentCategory {
  ORTAK
  GRUP
  TUTANAK_EK
  RAPOR_EK
  UYE_YUKLEMESI
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum AuditAction {
  USER_LOGIN
  USER_LOGIN_FAILED
  USER_LOGOUT
  USER_SIGNUP
  USER_APPROVED
  USER_REJECTED
  USER_SUSPENDED
  USER_DELETED
  USER_ROLE_ADDED
  USER_ROLE_REMOVED
  USER_GROUP_CHANGED
  INVITE_CREATED
  INVITE_REVOKED
  INVITE_ACCEPTED
  BOARD_POST_CREATED
  BOARD_POST_UPDATED
  BOARD_POST_REMOVED
  NOTICE_CREATED
  NOTICE_UPDATED
  NOTICE_REMOVED
  DISCUSSION_CREATED
  DISCUSSION_UPDATED
  DISCUSSION_REMOVED
  DISCUSSION_REPLY_CREATED
  DISCUSSION_REPLY_REMOVED
  MEETING_CREATED
  MEETING_UPDATED
  MEETING_REMOVED
  MINUTE_CREATED
  MINUTE_UPDATED
  REPORT_CREATED
  REPORT_UPDATED
  DOCUMENT_UPLOADED
  DOCUMENT_REMOVED
  RECORD_CREATED
  RECORD_UPDATED
  RECORD_DELETED
  RECORD_RESTORED
  SETTINGS_CHANGED
  KPI_CUSTOM_CREATED
  KPI_CUSTOM_UPDATED
  KPI_CUSTOM_APPROVED
  KPI_CUSTOM_REJECTED
  KPI_CUSTOM_REVISED
  KPI_BASELINE_CHANGED
  KPI_EVIDENCE_ADDED
  KPI_METRIC_EVENT_CREATED
  KPI_FIXED_TARGET_SET
  MEETING_RESULT_CREATED
  REPORT_TEMPLATE_CREATED
}

enum KpiMetricCode {
  KPI_PROJECT_IDEA_TOTAL
  KPI_PROJECT_APPLICATION_TOTAL
  KPI_PROJECT_APPLICATION_DIRECT_TOTAL
  KPI_PROJECT_APPLICATION_GUIDANCE_TOTAL
  KPI_SUCCESSFUL_PROJECT_TOTAL
  KPI_EVENT_ATTENDED_TOTAL
  KPI_EVENT_ORGANIZED_TOTAL
  KPI_CONTENT_TOTAL
  KPI_STAKEHOLDER_TOTAL
}

enum KpiSourceType {
  PROJECT_IDEA
  PROJECT_APPLICATION
  SUCCESSFUL_PROJECT
  EVENT
  CONTENT
  STAKEHOLDER
}

enum KpiCustomStatus {
  DRAFT
  ACTIVE
  COMPLETED
  OVERACHIEVED
}

enum KpiApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum KpiAssigneeType {
  USER_SINGLE
  USER_MULTI
  GROUP
}

enum KpiRevisionField {
  TARGET_VALUE
  TARGET_DATE
}

enum KpiEvidenceType {
  COMPLETED
  OVERACHIEVED
}

// ============================================================
// AUTH / USER / GROUP
// ============================================================

model User {
  id              String      @id @default(cuid())
  email           String      @unique
  // Faz 9: ad.soyad biçiminde kullanıcı adı; opsiyonel (eski kayıtlarda boş).
  // Login akışı e-posta VEYA kullanıcı adı kabul eder.
  username        String?     @unique
  emailVerified   DateTime?
  passwordHash    String?     // null for Google-only users
  name            String?
  image           String?     // 256x256 webp avatar (storage:<key>)
  imageLarge      String?     // 1024x1024 webp lightbox (storage:<key>)
  status          UserStatus  @default(PENDING_APPROVAL)
  groupId         String?
  group           Group?      @relation(fields: [groupId], references: [id], onDelete: SetNull)
  profile         Profile?
  roles           RoleAssignment[]
  accounts        AuthAccount[]
  sessions        AuthSession[]
  createdInvites  Invite[]     @relation("InviteCreator")
  boardPosts      BoardPost[]
  notices         Notice[]
  discussions     Discussion[]
  discussionReplies DiscussionReply[]
  meetings        Meeting[]
  minutes         MeetingMinute[]
  reports         Report[]
  groupNotes      GroupNote[]
  documents       Document[]
  projectApps     ProjectApplicationRecord[]
  successProjects SuccessfulProjectRecord[]
  projectIdeas    ProjectIdeaRecord[]
  events          EventRecord[]
  disseminations  DisseminationRecord[]
  trainings       TrainingPresentationRecord[]
  contents        ContentRecord[]
  stakeholders    StakeholderRecord[]
  kpiMetricEvents KpiMetricEvent[]     @relation("KpiMetricEventActor")
  kpiCustomsCreated KpiCustom[]        @relation("KpiCustomCreator")
  kpiCustomsApproved KpiCustom[]       @relation("KpiCustomApprover")
  kpiCustomAssignees KpiCustomAssignee[] @relation("KpiCustomAssigneeUser")
  kpiCustomRevisions KpiCustomRevision[] @relation("KpiCustomRevisionActor")
  kpiBaselineChanges KpiBaselineHistory[] @relation("KpiBaselineActor")
  kpiEvidenceUploads KpiCustomEvidence[] @relation("KpiEvidenceUploader")
  auditLogs       AuditLog[]
  notifications   Notification[]
  meetingResultsCreated MeetingResult[] @relation("MeetingResultCreator")
  reportTemplatesCreated ReportTemplate[] @relation("ReportTemplateCreator")
  approvedById    String?
  approvedBy      User?        @relation("UserApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedUsers   User[]       @relation("UserApprover")
  approvedAt      DateTime?
  rejectedReason  String?
  lastLoginAt     DateTime?
  failedLoginCount Int         @default(0)
  lockedUntil     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([groupId])
  @@index([status])
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String?  // e.g., Dr., Prof.
  position    String?  // job title
  organization String?
  phone       String?
  // Faz 9: il / şehir bilgisi (üye toplu içe aktarma şablonu için).
  city        String?
  bio         String?
  expertise   String[] @default([])
  themePref   String?  // "light" | "dark" | "system"
  // Faz 6: üye profil CV'si (ayrı storage anahtarı; User.image fotoğraf için).
  cvStorageKey String?
  cvOriginalName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Group {
  // Faz 7: `code` formerly a `GroupCode` enum limited to 5 values.
  // Replaced with a free-form String so admins can create new groups at
  // runtime. Legacy rows (UAK/E2SC/DFSF/PGD/PA) keep their codes.
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  description String?
  users       User[]
  boardPosts  BoardPost[]
  notices     Notice[]
  discussions Discussion[]
  meetings    Meeting[]
  reports     Report[]
  groupNotes  GroupNote[]
  documents   Document[]
  kpiMetricEvents KpiMetricEvent[]
  kpiCustoms  KpiCustom[]
  kpiCustomAssignees KpiCustomAssignee[] @relation("KpiCustomAssigneeGroup")
  fixedTargets       KpiFixedTarget[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model RoleAssignment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role
  grantedById String?
  createdAt DateTime @default(now())

  @@unique([userId, role])
  @@index([role])
}

// Auth.js (NextAuth v5) tables — prisma adapter compatible
model AuthAccount {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  email      String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([email])
}

model Invite {
  id          String       @id @default(cuid())
  email       String
  tokenHash   String       @unique
  groupId     String?
  roles       Role[]       @default([])
  status      InviteStatus @default(PENDING)
  expiresAt   DateTime
  createdById String
  createdBy   User         @relation("InviteCreator", fields: [createdById], references: [id], onDelete: Cascade)
  acceptedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime     @default(now())

  @@index([email])
  @@index([status])
}

// ============================================================
// ATTACHMENTS (shared)
// ============================================================

model Attachment {
  id            String   @id @default(cuid())
  storageKey    String   // path under UPLOAD_DIR (hash-based)
  originalName  String
  mimeType      String
  size          Int
  sha256        String?
  uploadedById  String
  createdAt     DateTime @default(now())

  boardPostId   String?
  boardPost     BoardPost? @relation(fields: [boardPostId], references: [id], onDelete: Cascade)

  meetingId     String?
  meeting       Meeting? @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  minuteId      String?
  minute        MeetingMinute? @relation(fields: [minuteId], references: [id], onDelete: Cascade)

  reportId      String?
  report        Report? @relation(fields: [reportId], references: [id], onDelete: Cascade)

  groupNoteId   String?
  groupNote     GroupNote? @relation(fields: [groupNoteId], references: [id], onDelete: Cascade)

  documentId    String?
  document      Document? @relation(fields: [documentId], references: [id], onDelete: Cascade)

  projectAppId  String?
  projectApp    ProjectApplicationRecord? @relation(fields: [projectAppId], references: [id], onDelete: Cascade)

  successProjectId String?
  successProject   SuccessfulProjectRecord? @relation(fields: [successProjectId], references: [id], onDelete: Cascade)

  projectIdeaId String?
  projectIdea   ProjectIdeaRecord? @relation(fields: [projectIdeaId], references: [id], onDelete: Cascade)

  eventId       String?
  event         EventRecord? @relation(fields: [eventId], references: [id], onDelete: Cascade)

  disseminationId String?
  dissemination   DisseminationRecord? @relation(fields: [disseminationId], references: [id], onDelete: Cascade)

  trainingId    String?
  training      TrainingPresentationRecord? @relation(fields: [trainingId], references: [id], onDelete: Cascade)

  contentId     String?
  content       ContentRecord? @relation(fields: [contentId], references: [id], onDelete: Cascade)

  stakeholderId String?
  stakeholder   StakeholderRecord? @relation(fields: [stakeholderId], references: [id], onDelete: Cascade)

  noticeId      String?
  notice        Notice? @relation(fields: [noticeId], references: [id], onDelete: Cascade)

  discussionId  String?
  discussion    Discussion? @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  kpiCustomEvidence KpiCustomEvidence?

  meetingResultId String?
  meetingResult   MeetingResult? @relation(fields: [meetingResultId], references: [id], onDelete: Cascade)

  reportTemplateId String?
  reportTemplate   ReportTemplate? @relation(fields: [reportTemplateId], references: [id], onDelete: Cascade)

  @@index([uploadedById])
  @@index([boardPostId])
  @@index([meetingId])
  @@index([minuteId])
  @@index([reportId])
  @@index([groupNoteId])
  @@index([documentId])
  @@index([meetingResultId])
  @@index([reportTemplateId])
}

// ============================================================
// BOARDS
// ============================================================

model BoardPost {
  id          String          @id @default(cuid())
  scope       BoardScope
  kind        BoardPostKind
  title       String
  body        String          @db.Text
  // Faz 6: genel panoda editörün "Değerlendirme/Yorum"
  // metni için ayrı alan. Grup panosunda boş bırakılır.
  assessment  String?         @db.Text
  tags        String[]        @default([])
  externalUrl String?
  pinned      Boolean         @default(false)
  status      BoardPostStatus @default(PUBLISHED)
  authorId    String
  author      User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  groupId     String?
  group       Group?          @relation(fields: [groupId], references: [id], onDelete: SetNull)
  attachments Attachment[]
  publishedAt DateTime        @default(now())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  @@index([scope, publishedAt])
  @@index([groupId])
  @@index([authorId])
  @@index([pinned])
}

// ============================================================
// NOTICES (Faz 9 — Bildirimler)
// ============================================================

model Notice {
  id          String      @id @default(cuid())
  scope       NoticeScope
  kind        BoardPostKind @default(NEWS)
  title       String
  body        String      @db.Text
  externalUrl String?
  pinned      Boolean     @default(false)
  authorId    String
  author      User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  // GROUP scope için zorunlu; GENERAL scope için null.
  groupId     String?
  group       Group?      @relation(fields: [groupId], references: [id], onDelete: SetNull)
  // Opsiyonel — bildirimin atıfta bulunduğu olay tarihi (toplantı saati,
  // başvuru son tarihi vb.). `publishedAt`/`createdAt` ise yayım anıdır.
  eventAt      DateTime?
  eventStartAt DateTime?
  eventEndAt   DateTime?
  attachments Attachment[]
  publishedAt DateTime    @default(now())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  @@index([scope, publishedAt])
  @@index([groupId, publishedAt])
  @@index([authorId])
  @@index([eventAt])
  @@index([eventStartAt])
  @@index([eventEndAt])
}

// ============================================================
// FORUM (Faz 10 — Grup içi konu / tartışma)
// ============================================================
//
// Çalışma grubu kapsamlı, forum-tarzı konu ve cevap akışı. Aynı gruba
// üye olan herhangi bir aktif kullanıcı konu başlatabilir ve cevap
// yazabilir; admin tüm grupları okuyabilir.

model Discussion {
  id          String   @id @default(cuid())
  groupId     String
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  title       String
  body        String   @db.Text
  pinned      Boolean  @default(false)
  locked      Boolean  @default(false) // cevapları kapatmak için (admin/moderatör)
  replies     DiscussionReply[]
  attachments Attachment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([groupId, createdAt])
  @@index([groupId, pinned])
  @@index([authorId])
}

model DiscussionReply {
  id           String     @id @default(cuid())
  discussionId String
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  authorId     String
  author       User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body         String     @db.Text
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  @@index([discussionId, createdAt])
  @@index([authorId])
}

// ============================================================
// MEETINGS / MINUTES / REPORTS
// ============================================================

model Meeting {
  id          String          @id @default(cuid())
  groupId     String
  group       Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  title       String
  startAt     DateTime
  endAt       DateTime?
  location    String?
  onlineUrl   String?
  description String?
  agenda      String?          @db.Text
  pinToBoard  Boolean         @default(false)
  createdById String
  createdBy   User            @relation(fields: [createdById], references: [id], onDelete: Cascade)
  minutes     MeetingMinute[]
  attachments Attachment[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  @@index([groupId, startAt])
}

model MeetingMinute {
  id          String     @id @default(cuid())
  meetingId   String
  meeting     Meeting    @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  date        DateTime
  attendees   String     @db.Text
  topics      String     @db.Text
  decisions   String     @db.Text
  summary     String?    @db.Text
  authorId    String
  author      User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  attachments Attachment[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  @@index([meetingId])
}

model Report {
  id          String     @id @default(cuid())
  groupId     String
  group       Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  kind        ReportKind
  title       String
  periodStart DateTime?
  periodEnd   DateTime?
  summary     String?    @db.Text
  body        String?    @db.Text
  outputs     String?    @db.Text
  authorId    String
  author      User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  attachments Attachment[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  @@index([groupId, kind, createdAt])
  @@index([authorId, createdAt])
  @@map("GroupReport")
}

enum GroupNoteScope {
  GENERAL
  GROUP
}

model GroupNote {
  id          String        @id @default(cuid())
  scope       GroupNoteScope @default(GROUP)
  groupId     String?
  group       Group?        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  kind        GroupNoteKind
  title       String
  body        String        @db.Text
  authorId    String
  author      User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  attachments Attachment[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  @@index([groupId, kind, createdAt])
  @@index([authorId, createdAt])
}

// ============================================================
// DOCUMENTS
// ============================================================

model Document {
  id          String           @id @default(cuid())
  category    DocumentCategory
  title       String
  description String?
  groupId     String?
  group       Group?           @relation(fields: [groupId], references: [id], onDelete: SetNull)
  tags        String[]         @default([])
  uploadedById String
  uploadedBy   User            @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  attachments Attachment[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?

  @@index([category])
  @@index([groupId])
}

// ============================================================
// INDIVIDUAL RECORDS
// ============================================================

model ProjectApplicationRecord {
  id              String                   @id @default(cuid())
  ownerId         String
  owner           User                     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  projectName     String
  // Legacy fields (Faz 6 öncesi). Yeni form bunları yazmaz — geriye dönük
  // veri için tutuluyor. Detay ekranı `programName` boşsa `program`u gösterir.
  program         String?
  callName        String?
  applicationDate DateTime?
  budget          Decimal?                 @db.Decimal(18, 2)
  requestedSupport Decimal?                @db.Decimal(18, 2)
  status          ProjectApplicationStatus @default(PLANLANIYOR)
  // Legacy enum (BIREYSEL / DFT_ILE_BIRLIKTE). Yeni formda `memberFunction`
  // (Bireysel / DFT ile Birlikte / Danışmanlık) kullanılıyor.
  kind            ProjectApplicationKind   @default(BIREYSEL)
  partnerMemberIds String[]                @default([])
  notes           String?                  @db.Text
  // Faz 8 yeni alanları
  fundCategory    String?                  // ULUSAL | AB | DIGER_ULUSLARARASI
  fundSubType     String?                  // örn. TÜBİTAK, Erasmus+, EBRD …
  grantProvider   String?                  // Hibe sağlayıcısının tam adı / kısaltması
  programName     String?                  // Programın tam adı (yeni)
  applicantOrg    String?                  // İlgili kurum / kuruluş
  applicantRole   String?                  // Başvuru Sahibi/Koordinatör/Lider | Ortak | İştirakçi
  memberFunction  String?                  // BIREYSEL | DFT_ILE_BIRLIKTE | DANISMANLIK
  attachments     Attachment[]
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  deletedAt       DateTime?

  @@index([ownerId])
  @@index([status])
}

model SuccessfulProjectRecord {
  id              String       @id @default(cuid())
  ownerId         String
  owner           User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  projectName     String
  // Legacy fields (Faz 6 öncesi) — yeni form bunları yazmaz.
  program         String?
  callName        String?
  applicationDate DateTime?
  resultDate      DateTime?
  totalBudget     Decimal?     @db.Decimal(18, 2)
  supportAmount   Decimal?     @db.Decimal(18, 2)
  role            String?
  kind            String?
  resultDocument  String?
  // Faz 6: proje konsorsiyumu — ortak kuruluş ve paydaş listesi.
  consortium      String?      @db.Text
  summary         String?      @db.Text
  // Faz 8 yeni alanları (Proje Başvurusu ile aynı paralel set)
  fundCategory    String?
  fundSubType     String?
  grantProvider   String?
  programName     String?
  applicantOrg    String?
  applicantRole   String?
  memberFunction  String?
  acceptanceDate  DateTime?    // Proje Kabul Tarihi
  attachments     Attachment[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  @@index([ownerId])
}

model ProjectIdeaRecord {
  id             String           @id @default(cuid())
  ownerId        String
  owner          User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title          String
  // Yeni form yalnızca: potentialProgram, grantProvider, budget, summary
  // alanlarını yazar. Kalanlar legacy: stage/callTopic/potentialPartners/
  // nextStep/targetDate/notes — eski kayıtlar için tutuluyor.
  potentialProgram String?
  grantProvider  String?          // Faz 8: İlgili / potansiyel hibe sağlayıcısı
  budget         Decimal?         @db.Decimal(18, 2) // Faz 8: tahmini bütçe
  callTopic      String?
  stage          ProjectIdeaStage @default(FIKIR)
  potentialPartners String?
  summary        String?          @db.Text          // Faz 8: "Proje Özeti"
  nextStep       String?
  targetDate     DateTime?
  notes          String?          @db.Text
  attachments    Attachment[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?

  @@index([ownerId])
  @@index([stage])
}

model EventRecord {
  id          String       @id @default(cuid())
  ownerId     String
  owner       User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name        String
  kind        String?
  date        DateTime
  location    String?
  role        String?
  topic       String?
  // Faz 6 yeni alanlar
  organizer   String?
  format      String?      // "ONLINE" | "FIZIKI"
  externalUrl String?
  summary     String?      @db.Text
  notes       String?      @db.Text
  attachments Attachment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  @@index([ownerId])
  @@index([date])
}

model DisseminationRecord {
  id           String       @id @default(cuid())
  ownerId      String
  owner        User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title        String
  date         DateTime
  location     String?
  kind         String?
  audience     String?
  participantCount Int?
  relatedTopic String?
  summary      String?      @db.Text
  notes        String?      @db.Text
  attachments  Attachment[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  @@index([ownerId])
  @@index([date])
}

model TrainingPresentationRecord {
  id           String       @id @default(cuid())
  ownerId      String
  owner        User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title        String
  date         DateTime
  location     String?
  audience     String?
  participantCount Int?
  role         String?
  summary      String?      @db.Text
  notes        String?      @db.Text
  attachments  Attachment[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  @@index([ownerId])
}

model ContentRecord {
  id          String       @id @default(cuid())
  ownerId     String
  owner       User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title       String
  // Faz 8: yeni `kind` listesi: Bilgi Notu / Kitap / Makale / Rapor / Sunum / Video
  kind        String?
  // `date` legacy — yeni form tarih sormuyor. Eski kayıtlarda doluydu;
  // yeni satırlar için `createdAt` referans alınır. Sütun NOT NULL kalmaya
  // devam eder; yeni form `new Date()` ile besler.
  date        DateTime
  summary     String?      @db.Text
  mainDocument String?
  tags        String[]     @default([])
  notes       String?      @db.Text
  // Faz 8: dış bağlantı (örn. video / makale URL'si).
  externalUrl String?
  attachments Attachment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  @@index([ownerId])
}

// ============================================================
// STAKEHOLDERS (Faz 8 — Paydaş kaydı)
// ============================================================

enum StakeholderKind {
  YERLI
  YABANCI
}

model StakeholderRecord {
  id           String           @id @default(cuid())
  ownerId      String
  owner        User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  fullName     String
  positionTitle String?         // Ünvan
  kind         StakeholderKind  @default(YERLI)
  organization String?
  linkedinUrl  String?
  email        String?
  city         String?
  country      String?
  tags         String[]         @default([])
  description  String?          @db.Text
  attachments  Attachment[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  deletedAt    DateTime?

  @@index([ownerId])
  @@index([kind])
}

model KpiMetricEvent {
  id          String        @id @default(cuid())
  metricCode  KpiMetricCode
  groupId     String
  group       Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  actorUserId String
  actorUser   User          @relation("KpiMetricEventActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  sourceType  KpiSourceType
  sourceId    String
  // +1: create, -1: soft delete
  delta       Int
  occurredAt  DateTime      @default(now())
  createdAt   DateTime      @default(now())

  @@index([groupId, metricCode, occurredAt])
  @@index([actorUserId, occurredAt])
  @@index([sourceType, sourceId])
  @@unique([metricCode, sourceType, sourceId, delta])
}

model KpiCustom {
  id              String             @id @default(cuid())
  groupId         String
  group           Group              @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name            String
  description     String?            @db.Text
  baselineValue   Decimal?           @db.Decimal(18, 2)
  baselineDate    DateTime?
  targetValue     Decimal?           @db.Decimal(18, 2)
  targetDate      DateTime?
  actualValue     Decimal?           @db.Decimal(18, 2)
  status          KpiCustomStatus    @default(DRAFT)
  approvalStatus  KpiApprovalStatus  @default(PENDING)
  createdById     String
  createdBy       User               @relation("KpiCustomCreator", fields: [createdById], references: [id], onDelete: Cascade)
  approvedById    String?
  approvedBy      User?              @relation("KpiCustomApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt      DateTime?
  completedAt     DateTime?
  assignees       KpiCustomAssignee[]
  revisions       KpiCustomRevision[]
  baselineHistory KpiBaselineHistory[]
  evidences       KpiCustomEvidence[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?

  @@index([groupId, createdAt])
  @@index([status, approvalStatus])
  @@index([createdById, createdAt])
}

model KpiCustomAssignee {
  id           String          @id @default(cuid())
  kpiId        String
  kpi          KpiCustom       @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  assigneeType KpiAssigneeType
  userId       String?
  user         User?           @relation("KpiCustomAssigneeUser", fields: [userId], references: [id], onDelete: Cascade)
  groupId      String?
  group        Group?          @relation("KpiCustomAssigneeGroup", fields: [groupId], references: [id], onDelete: Cascade)
  createdAt    DateTime        @default(now())

  @@index([kpiId, assigneeType])
  @@index([userId])
  @@index([groupId])
}

model KpiCustomRevision {
  id          String           @id @default(cuid())
  kpiId       String
  kpi         KpiCustom        @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  field       KpiRevisionField
  oldValue    Json?
  newValue    Json?
  changedById String
  changedBy   User             @relation("KpiCustomRevisionActor", fields: [changedById], references: [id], onDelete: Cascade)
  reason      String?
  createdAt   DateTime         @default(now())

  @@index([kpiId, createdAt])
  @@index([changedById, createdAt])
}

model KpiBaselineHistory {
  id          String           @id @default(cuid())
  kpiId       String
  kpi         KpiCustom        @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  field       KpiRevisionField
  oldValue    Json?
  newValue    Json?
  changedById String
  changedBy   User             @relation("KpiBaselineActor", fields: [changedById], references: [id], onDelete: Cascade)
  reason      String?
  createdAt   DateTime         @default(now())

  @@index([kpiId, createdAt])
  @@index([changedById, createdAt])
}

model KpiCustomEvidence {
  id           String          @id @default(cuid())
  kpiId        String
  kpi          KpiCustom       @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  attachmentId String          @unique
  attachment   Attachment      @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  evidenceType KpiEvidenceType
  uploadedById String
  uploadedBy   User            @relation("KpiEvidenceUploader", fields: [uploadedById], references: [id], onDelete: Cascade)
  createdAt    DateTime        @default(now())

  @@index([kpiId, evidenceType, createdAt])
  @@index([uploadedById, createdAt])
}

// ============================================================
// NOTIFICATIONS / AUDIT
// ============================================================

model Notification {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind       String
  title      String
  body       String?
  link       String?
  readAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([userId, readAt])
}

model AuditLog {
  id        String      @id @default(cuid())
  action    AuditAction
  actorId   String?
  actor     User?       @relation(fields: [actorId], references: [id], onDelete: SetNull)
  targetType String?    // e.g., "User", "BoardPost"
  targetId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime   @default(now())

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@index([targetType, targetId])
}

// ============================================================
// SETTINGS / DICTIONARY
// ============================================================

model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model DictionaryItem {
  id        String   @id @default(cuid())
  kind      String   // e.g., "program", "event-kind"
  code      String
  label     String
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([kind, code])
  @@index([kind, active, order])
}

model KpiFixedTarget {
  id            String        @id @default(cuid())
  groupId       String
  group         Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  metricCode    KpiMetricCode
  baselineValue Decimal?      @db.Decimal(18, 2)
  baselineDate  DateTime?
  targetValue   Decimal?      @db.Decimal(18, 2)
  targetDate    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([groupId, metricCode])
  @@index([groupId])
}

model MeetingResult {
  id               String       @id @default(cuid())
  title            String
  description      String?      @db.Text
  startAt          DateTime
  endAt            DateTime
  scope            String       // "GENEL" | "MRDK"
  mrdkTarget       String?      // "ALL" | "SPECIFIC"
  targetGroupIds   String[]     @default([])
  attachments      Attachment[]
  createdById      String
  createdBy        User         @relation("MeetingResultCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?

  @@index([createdById])
}

model ReportTemplate {
  id             String       @id @default(cuid())
  title          String
  description    String?      @db.Text
  scope          String       // "GENEL" | "GROUPS"
  targetGroupIds String[]     @default([])
  attachments    Attachment[]
  createdById    String
  createdBy      User         @relation("ReportTemplateCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@index([createdById])
  @@index([scope, createdAt])
}
