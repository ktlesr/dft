# --------------------------------------------------------------
# DFT Portal — Environment variables
# --------------------------------------------------------------
# Copy to .env and fill in. Never commit .env with real secrets.
# --------------------------------------------------------------

# App
NODE_ENV=development
NEXT_PUBLIC_APP_NAME="DFT Portal"
APP_URL=http://localhost:3000

# Auth.js (NextAuth v5)
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-to-a-strong-random-32byte-base64
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Google OAuth (Cloud Console → OAuth 2.0 Client IDs)
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Database (docker compose up -d postgres)
DATABASE_URL="postgresql://dft:dft_dev_pass@localhost:5433/dft_portal?schema=public"

# Initial admin (used by seed script)
SEED_ADMIN_EMAIL=admin@dft.local
SEED_ADMIN_PASSWORD=Admin!2026Dev
SEED_ADMIN_NAME="DFT Admin"

# Storage (local disk)
UPLOAD_DIR=./storage/uploads
MAX_UPLOAD_BYTES=15728640

# Feature flags
ENABLE_PUBLIC_SIGNUP=true
REQUIRE_ADMIN_APPROVAL=true

# --------------------------------------------------------------
# PRODUCTION / DOKPLOY EXTRAS
# Only required when you run the full docker-compose.yml stack
# (app + postgres) — not needed for local `pnpm dev`.
# --------------------------------------------------------------

# Strong DB password (replaces dft_dev_pass).
# Dokploy: set this in the environment panel, not in a committed file.
POSTGRES_PASSWORD=change-me-strong

# Apply the Prisma schema on every container start:
#   - if prisma/migrations exists → migrate deploy
#   - otherwise                   → db push
# No action needed from env; docker-entrypoint.sh handles it.
